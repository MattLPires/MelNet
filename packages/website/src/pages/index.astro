---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MelNet — LAN Virtual Segura para Jogos">
  <main>
    <!-- HERO -->
    <section class="hero" id="hero">
      <div class="hero-bg" aria-hidden="true">
        <div class="hex hex-1"></div>
        <div class="hex hex-2"></div>
        <div class="hex hex-3"></div>
        <div class="hex hex-4"></div>
        <div class="hex hex-5"></div>
      </div>

      <!-- Floating bees in hero -->
      <div class="bee-float-left" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 64 64" fill="none">
          <ellipse cx="22" cy="18" rx="9" ry="6" fill="#F5A623" opacity="0.25"/>
          <ellipse cx="42" cy="18" rx="9" ry="6" fill="#F5A623" opacity="0.25"/>
          <ellipse cx="32" cy="34" rx="13" ry="16" fill="#F5A623"/>
          <rect x="19" y="30" width="26" height="3.5" rx="1.5" fill="#fff" opacity="0.3"/>
          <rect x="19" y="37" width="26" height="3.5" rx="1.5" fill="#fff" opacity="0.3"/>
          <circle cx="27" cy="28" r="2.5" fill="#fff"/>
          <circle cx="37" cy="28" r="2.5" fill="#fff"/>
          <circle cx="27.5" cy="28.5" r="1" fill="#2D2A24"/>
          <circle cx="37.5" cy="28.5" r="1" fill="#2D2A24"/>
        </svg>
      </div>
      <div class="bee-float-right" aria-hidden="true">
        <svg width="36" height="36" viewBox="0 0 64 64" fill="none">
          <ellipse cx="22" cy="18" rx="9" ry="6" fill="#F5A623" opacity="0.25"/>
          <ellipse cx="42" cy="18" rx="9" ry="6" fill="#F5A623" opacity="0.25"/>
          <ellipse cx="32" cy="34" rx="13" ry="16" fill="#F5A623"/>
          <rect x="19" y="30" width="26" height="3.5" rx="1.5" fill="#fff" opacity="0.3"/>
          <rect x="19" y="37" width="26" height="3.5" rx="1.5" fill="#fff" opacity="0.3"/>
          <circle cx="27" cy="28" r="2.5" fill="#fff"/>
          <circle cx="37" cy="28" r="2.5" fill="#fff"/>
          <circle cx="27.5" cy="28.5" r="1" fill="#2D2A24"/>
          <circle cx="37.5" cy="28.5" r="1" fill="#2D2A24"/>
        </svg>
      </div>

      <div class="container hero-content">
        <div class="hero-bee" aria-hidden="true">
          <svg width="72" height="72" viewBox="0 0 64 64" fill="none">
            <ellipse cx="22" cy="18" rx="10" ry="7" fill="#F5A623" opacity="0.3"/>
            <ellipse cx="42" cy="18" rx="10" ry="7" fill="#F5A623" opacity="0.3"/>
            <ellipse cx="32" cy="36" rx="14" ry="18" fill="#F5A623"/>
            <rect x="18" y="32" width="28" height="4" rx="2" fill="#fff" opacity="0.3"/>
            <rect x="18" y="40" width="28" height="4" rx="2" fill="#fff" opacity="0.3"/>
            <circle cx="27" cy="30" r="3" fill="#fff"/>
            <circle cx="37" cy="30" r="3" fill="#fff"/>
            <circle cx="27.5" cy="30.5" r="1.2" fill="#2D2A24"/>
            <circle cx="37.5" cy="30.5" r="1.2" fill="#2D2A24"/>
            <path d="M29 44 Q32 47 35 44" stroke="#fff" stroke-width="1.5" fill="none" opacity="0.5"/>
          </svg>
        </div>
        <h1 class="hero-title">Jogue com amigos.<br/><span>Sem risco. Sem complicação.</span></h1>
        <p class="hero-sub">Crie uma rede LAN virtual segura em segundos. Seu IP real nunca é exposto a outros jogadores.</p>
        <a href="#download" class="btn-primary">Baixar MelNet</a>
        <div class="hero-os">
          <span>Windows</span>
          <span class="hero-os-sep"></span>
          <span>Linux</span>
        </div>
      </div>
    </section>

    <!-- COMO FUNCIONA -->
    <section class="section section-honey" id="como-funciona">
      <div class="container">
        <h2 class="section-title">Como funciona</h2>
        <p class="section-sub">Três passos simples para jogar em rede local com seus amigos.</p>
        <div class="steps">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-icon" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 48 48"><polygon points="24,4 44,14 44,34 24,44 4,34 4,14" fill="none" stroke="#F5A623" stroke-width="1.5"/><circle cx="24" cy="24" r="4" fill="#F5A623" opacity="0.3"/></svg>
            </div>
            <h3>Crie uma sala</h3>
            <p>Escolha um nome, defina o limite de jogadores e receba um código de convite único.</p>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-icon" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 48 48"><polygon points="24,4 44,14 44,34 24,44 4,34 4,14" fill="none" stroke="#F5A623" stroke-width="1.5"/><circle cx="18" cy="22" r="2.5" fill="#F5A623" opacity="0.3"/><circle cx="30" cy="22" r="2.5" fill="#F5A623" opacity="0.3"/><circle cx="24" cy="30" r="2.5" fill="#F5A623" opacity="0.3"/></svg>
            </div>
            <h3>Convide amigos</h3>
            <p>Compartilhe o código de convite. Seus amigos entram na sala em segundos.</p>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-icon" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 48 48"><polygon points="24,4 44,14 44,34 24,44 4,34 4,14" fill="none" stroke="#F5A623" stroke-width="1.5"/><path d="M18 20 L24 28 L30 20" fill="none" stroke="#F5A623" stroke-width="1.5" opacity="0.5"/></svg>
            </div>
            <h3>Jogue juntos</h3>
            <p>A rede LAN virtual é criada automaticamente. Abra o jogo e divirta-se!</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SEGURANÇA -->
    <section class="section" id="seguranca">
      <div class="container">
        <h2 class="section-title">Segurança de verdade</h2>
        <p class="section-sub">Projetado desde o início para proteger você e seus amigos.</p>
        <div class="security-grid">
          <div class="sec-card">
            <div class="sec-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/></svg></div>
            <h3>IP real oculto</h3>
            <p>Todo o tráfego passa pelo servidor relay. Outros jogadores veem apenas seu IP virtual.</p>
          </div>
          <div class="sec-card">
            <div class="sec-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></div>
            <h3>Acesso remoto bloqueado</h3>
            <p>RDP, VNC e SSH são bloqueados automaticamente pelo firewall integrado.</p>
          </div>
          <div class="sec-card">
            <div class="sec-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12,2 22,8.5 22,15.5 12,22 2,15.5 2,8.5"/></svg></div>
            <h3>Salas isoladas</h3>
            <p>Cada sala tem sua própria sub-rede virtual. Zero comunicação entre salas diferentes.</p>
          </div>
          <div class="sec-card">
            <div class="sec-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4" stroke-width="2"/></svg></div>
            <h3>Criptografia forte</h3>
            <p>ChaCha20-Poly1305 protege cada pacote entre você e o servidor.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- JOGOS COMPATÍVEIS -->
    <section class="section section-warm" id="jogos">
      <div class="container">
        <h2 class="section-title">Jogos compatíveis</h2>
        <p class="section-sub">Qualquer jogo com modo LAN funciona com o MelNet.</p>
        <div class="games">
          <span class="game">Minecraft</span>
          <span class="game">Counter-Strike</span>
          <span class="game">Age of Empires</span>
          <span class="game">Terraria</span>
          <span class="game">Valheim</span>
          <span class="game">Factorio</span>
          <span class="game">Left 4 Dead 2</span>
          <span class="game">Starbound</span>
          <span class="game game-more">e muito mais</span>
        </div>
      </div>
    </section>

    <!-- TUTORIAL -->
    <section class="section" id="tutorial">
      <div class="container">
        <h2 class="section-title">Comece em minutos</h2>
        <p class="section-sub">Passo a passo para começar a jogar.</p>
        <div class="timeline">
          <div class="tl-item"><div class="tl-dot"></div><div class="tl-content"><strong>Instalar</strong><span>Baixe e instale o MelNet no seu computador</span></div></div>
          <div class="tl-item"><div class="tl-dot"></div><div class="tl-content"><strong>Criar conta</strong><span>Cadastre-se ou entre como convidado</span></div></div>
          <div class="tl-item"><div class="tl-dot"></div><div class="tl-content"><strong>Criar sala</strong><span>Configure e receba o código de convite</span></div></div>
          <div class="tl-item"><div class="tl-dot"></div><div class="tl-content"><strong>Compartilhar</strong><span>Envie o código para seus amigos</span></div></div>
          <div class="tl-item"><div class="tl-dot"></div><div class="tl-content"><strong>Jogar</strong><span>Abra o jogo e conecte na LAN virtual!</span></div></div>
        </div>
      </div>
    </section>

    <!-- DOWNLOAD -->
    <section class="section section-honey" id="download">
      <div class="container">
        <h2 class="section-title">Download</h2>
        <p class="section-sub">Escolha seu sistema operacional.</p>
        <div class="dl-grid">
          <div class="dl-card">
            <h3>Windows</h3>
            <span class="dl-format">.exe (NSIS)</span>
            <span class="dl-meta">v1.0.0</span>
            <a href="https://github.com/MattLPires/MelNet/releases/latest/download/MelNet.Setup.0.1.0.exe" class="btn-primary dl-btn" aria-label="Baixar para Windows">Baixar</a>
          </div>
          <div class="dl-card">
            <h3>Linux</h3>
            <span class="dl-format">.deb / AppImage</span>
            <span class="dl-meta">v1.0.0</span>
            <a href="https://github.com/MattLPires/MelNet/releases/latest/download/melnet_0.1.0_amd64.deb" class="btn-primary dl-btn" aria-label="Baixar para Linux">Baixar</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section" id="faq">
      <div class="container">
        <h2 class="section-title">Perguntas frequentes</h2>
        <p class="section-sub">Tire suas dúvidas sobre o MelNet.</p>
        <div class="faq-section">
          <div class="faq">
            <details>
              <summary>O MelNet é gratuito?</summary>
              <p>Sim! O MelNet é gratuito e de código aberto.</p>
            </details>
            <details>
              <summary>Meu IP real fica exposto?</summary>
              <p>Não. Todo o tráfego passa pelo nosso servidor relay. Outros jogadores veem apenas seu IP virtual (10.x.x.x).</p>
            </details>
            <details>
              <summary>Quantos jogadores cabem em uma sala?</summary>
              <p>Cada sala suporta de 2 a 16 jogadores simultâneos.</p>
            </details>
            <details>
              <summary>Funciona com qualquer jogo?</summary>
              <p>O MelNet funciona com qualquer jogo que suporte modo LAN ou rede local — Minecraft, CS, Age of Empires, Terraria, Valheim e muitos outros.</p>
            </details>
            <details>
              <summary>Preciso criar conta para jogar?</summary>
              <p>Não é obrigatório. Você pode entrar como convidado com um nickname temporário.</p>
            </details>
            <details>
              <summary>O MelNet funciona no Linux?</summary>
              <p>Sim! Oferecemos pacotes .deb para distribuições Debian/Ubuntu e AppImage para outras distros.</p>
            </details>
          </div>
        </div>
      </div>
    </section>

    <!-- Floating bee decoration -->
    <div class="bee-corner" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 64 64" fill="none">
        <ellipse cx="22" cy="18" rx="9" ry="6" fill="#F5A623" opacity="0.3"/>
        <ellipse cx="42" cy="18" rx="9" ry="6" fill="#F5A623" opacity="0.3"/>
        <ellipse cx="32" cy="34" rx="13" ry="16" fill="#F5A623"/>
        <rect x="19" y="30" width="26" height="3.5" rx="1.5" fill="#fff" opacity="0.3"/>
        <rect x="19" y="37" width="26" height="3.5" rx="1.5" fill="#fff" opacity="0.3"/>
        <circle cx="27" cy="28" r="2.5" fill="#fff"/>
        <circle cx="37" cy="28" r="2.5" fill="#fff"/>
        <circle cx="27.5" cy="28.5" r="1" fill="#2D2A24"/>
        <circle cx="37.5" cy="28.5" r="1" fill="#2D2A24"/>
      </svg>
    </div>
  </main>
</Layout>
