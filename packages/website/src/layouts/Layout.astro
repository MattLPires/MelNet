---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

const navLinks = [
  { href: '#como-funciona', label: 'Como Funciona' },
  { href: '#seguranca', label: 'Segurança' },
  { href: '#download', label: 'Download' },
  { href: '#faq', label: 'FAQ' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="MelNet — Jogue com amigos em LAN virtual segura, sem expor seu IP. Crie salas, convide amigos e jogue juntos com proteção total." />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="LAN virtual segura para jogos multiplayer. Jogue com amigos sem expor seu IP real." />
    <meta property="og:image" content="/og-image.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-header__logo" aria-label="MelNet">MelNet</a>
        <nav>
          <ul class="site-header__nav">
            {navLinks.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Abrir menu">☰</button>
      </div>
    </header>

    <nav class="mobile-nav" id="mobile-nav" aria-label="Menu mobile">
      {navLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <slot />

    <footer class="site-footer">
      <div class="container">
        <div class="site-footer__inner">
          <div class="site-footer__logo">MelNet</div>
          <p class="site-footer__desc">LAN virtual segura para jogos. Jogue com amigos sem expor seu IP.</p>
          <p class="site-footer__copy">© 2026 MelNet. Código aberto sob licença MIT.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var nav = document.getElementById('mobile-nav');
        if (!btn || !nav) return;
        btn.addEventListener('click', function() {
          var open = nav.classList.toggle('open');
          btn.textContent = open ? '✕' : '☰';
        });
        nav.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', function() { nav.classList.remove('open'); btn.textContent = '☰'; });
        });
      })();
    </script>
  </body>
</html>
